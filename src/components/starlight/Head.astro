---
import config from 'virtual:starlight/user-config';
import { getCollection } from 'astro:content';

function normalizeEntryId(entryId: string) {
  if (entryId === 'index') return '';
  if (entryId.endsWith('/index')) return entryId.slice(0, -'/index'.length);
  return entryId;
}

const docs = await getCollection('docs');
const docsById = new Map(
  docs.map((entry) => [normalizeEntryId(entry.id), entry] as const)
);

const currentLocale = Astro.locals.starlightRoute.locale;
const currentId = normalizeEntryId(Astro.locals.starlightRoute.entry.id);
const localePrefix = currentLocale ? `${currentLocale}/` : '';
const baseId = currentLocale && currentId === currentLocale
  ? ''
  : localePrefix && currentId.startsWith(localePrefix)
    ? currentId.slice(localePrefix.length)
    : currentId;
const currentLang =
  currentLocale && config.locales?.[currentLocale]
    ? config.locales[currentLocale].lang
    : config.locales?.root?.lang;

function getTargetId(localeCode: string) {
  if (localeCode === 'root') return baseId;
  return baseId ? `${localeCode}/${baseId}` : localeCode;
}

const readyHreflangs = new Set(
  config.isMultilingual && config.locales
    ? Object.entries(config.locales)
        .filter(([code]) => {
          const entry = docsById.get(getTargetId(code));
          return Boolean(entry && entry.data.draft === false);
        })
        .map(([, locale]) => locale.lang)
    : []
);

const head = Astro.locals.starlightRoute.head.filter((entry) => {
  if (entry.tag !== 'link' || entry.attrs?.rel !== 'alternate') return true;
  const hreflang = typeof entry.attrs?.hreflang === 'string' ? entry.attrs.hreflang : '';
  if (baseId === '404') {
    return hreflang === currentLang;
  }
  return readyHreflangs.has(hreflang);
});
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
