---
import LabelList from './LabelList.astro';

interface Props {
  frontmatter?: {
    audience?: string;
    difficulty?: string;
    tags?: string[];
  };
}

const frontmatter = Astro.props.frontmatter ?? {};
const audience = frontmatter.audience ?? '';
const difficulty = frontmatter.difficulty ?? '';
const tags = Array.isArray(frontmatter.tags)
  ? frontmatter.tags.filter((t: string) => t.trim().length > 0)
  : [];
const hasInfo = !!(audience || difficulty || tags.length > 0);
---

{hasInfo && (
  <div class="loom-guide-info">
    {(audience || difficulty) && (
      <div class="loom-guide-info-row">
        {audience && <span class="loom-guide-badge">{audience}</span>}
        {difficulty && <span class="loom-guide-badge">{difficulty}</span>}
      </div>
    )}
    {tags.length > 0 && (
      <div class="loom-guide-info-tags">
        <LabelList labels={tags} />
      </div>
    )}
  </div>
)}

<style>
  .loom-guide-info {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
  }

  .loom-guide-info-row {
    display: flex;
    gap: 0.5rem;
  }

  .loom-guide-badge {
    padding: 0.3rem 0.7rem;
    border-radius: var(--loom-radius-sm, 0.5rem);
    background: var(--loom-surface);
    color: var(--loom-copy);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .loom-guide-info-tags {
    display: flex;
    align-items: center;
  }
</style>
