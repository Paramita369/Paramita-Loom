---
import { GUIDE_STALE_POLICY_TEXT } from '../utils/guideStalePolicy.js';
import {
  getExpectedSiteTypeForRoute,
  getExpectedTemplateForRoute,
  getRouteReaderSections,
  resolvePublicProjection,
} from '../utils/publicProjectionMap.ts';
import LabelList from './LabelList.astro';

interface GuideFrontmatter {
  guideVersion?: string;
  verifiedAt?: string;
  nextReviewAt?: string;
  content_family?: string;
  content_intent?: string;
  instruction_mode?: string;
  claim_regime?: string;
  site_type_projection?: string;
  projection_confidence?: 'low' | 'medium' | 'high' | string;
  publication_state?: 'private_preview_candidate' | 'public_candidate' | 'preview_deployment_candidate' | 'publish_ready' | string;
  target_template?: string;
  compat_primary_profile?: string;
  route_version?: string;
  route_origin?: string;
  route_signature?: string;
  recipe_key?: string;
  appendix_policy?: string;
  nav_hidden?: boolean;
  search_hidden?: boolean;
  stalePolicyCode?: 'remove_from_primary_entry_when_overdue' | string;
  stalePolicy?: string;
  platforms?: string[];
  audience?: string;
  difficulty?: string;
  verificationLevelCode?: 'doc_checked' | 'local_verified' | 'cross_platform_verified' | string;
  guide_audience?: 'end_user' | 'operator' | 'contributor' | string;
  guide_surface?: 'official_cli' | 'repo_self_hosted' | string;
  verification_class?:
    | 'researched_only'
    | 'dry_run_verified'
    | 'container_smoke_verified'
    | 'single_machine_verified'
    | 'multi_machine_verified'
    | 'stale_recheck_needed'
    | string;
  tested_on?: Array<{
    label?: string;
    platform?: string;
    host?: string;
    host_os?: string;
    image?: string;
    runtime?: string;
    verified_at?: string;
    note?: string;
  }>;
  evidence_refs?: Array<{
    label?: string;
    kind?: string;
    path?: string;
    target?: string;
    note?: string;
  }>;
  known_limitations?: string[];
  shipping_lane?: 'preview_only' | 'shipping_candidate' | 'shipping' | string;
  retest_trigger?: string[];
  updateTriggers?: string[];
  tags?: string[];
}

interface Props {
  title?: string;
  intro?: string;
  rows?: Array<{ label: string; value: string }>;
  tags?: string[];
  frontmatter?: GuideFrontmatter;
}

interface MetadataRow {
  label: string;
  value?: string;
  items?: string[];
}

interface MetadataSection {
  title: string;
  intro: string;
  rows: MetadataRow[];
}

const routeData = (Astro.locals.starlightRoute?.entry?.data ?? {}) as GuideFrontmatter;
const frontmatter = Astro.props.frontmatter ?? routeData;
const verificationLevelLabels: Record<string, string> = {
  doc_checked: '文件已核對',
  local_verified: '本地已驗證',
  cross_platform_verified: '跨平台已驗證',
};
const guideAudienceLabels: Record<string, string> = {
  end_user: '普通用家',
  operator: '系統操作員',
  contributor: '內容或 repo 維護者',
};
const guideSurfaceLabels: Record<string, string> = {
  official_cli: '官方 CLI 路線',
  repo_self_hosted: 'Repo 自行部署路線',
};
const verificationClassLabels: Record<string, string> = {
  researched_only: '只做文件核對',
  dry_run_verified: '只做流程演練',
  container_smoke_verified: '已用容器做基本 smoke 測試',
  single_machine_verified: '已在單機完成實測',
  multi_machine_verified: '已跨多台機器實測',
  stale_recheck_needed: '需要重新覆核',
};
const shippingLaneLabels: Record<string, string> = {
  preview_only: '公開預覽',
  shipping_candidate: '候選可出貨',
  shipping: '正式可出貨',
};
const updateTriggerLabels: Record<string, string> = {
  openclaw_release: 'OpenClaw 發布更新',
  dependency_major_bump: '關鍵依賴有大版本變動',
  verification_fail: '驗證步驟失效或結果改變',
  user_report: '收到讀者或使用者回報',
  docs_change: '相關文件或流程說明更新',
  installer_changed: 'installer 流程改動',
  onboarding_flow_changed: 'onboarding 流程改動',
  gateway_health_contract_changed: 'gateway / health 合約改動',
};
function formatLabelValue(value: string | undefined, labels: Record<string, string>) {
  if (!value) {
    return '';
  }
  return labels[value] ?? value;
}
function formatTextList(values: string[] | undefined) {
  return Array.isArray(values)
    ? values.map((value) => value.trim()).filter((value) => value.length > 0)
    : [];
}
function formatCodeItems(values: string[] | undefined, labels: Record<string, string>) {
  return Array.isArray(values)
    ? values
        .map((value) => labels[value] ?? value)
        .map((value) => value.trim())
        .filter((value) => value.length > 0)
    : [];
}
function formatTestedOn(values: GuideFrontmatter['tested_on']) {
  return Array.isArray(values)
    ? values
        .map((record) => {
          const label = record.label?.trim() ?? record.platform?.trim() ?? '';
          const details = [
            record.platform && record.platform !== label ? `平台：${record.platform}` : '',
            record.host ? `主機：${record.host}` : '',
            record.host_os ? `主機系統：${record.host_os}` : '',
            record.image ? `映像：${record.image}` : '',
            record.runtime ? `執行環境：${record.runtime}` : '',
            record.verified_at ? `驗證日：${record.verified_at}` : '',
            record.note ?? '',
          ].filter((value) => value.trim().length > 0);

          if (label.length === 0) {
            return details.join('；');
          }

          return details.length > 0 ? `${label}（${details.join('；')}）` : label;
        })
        .filter((value) => value.trim().length > 0)
    : [];
}
function formatEvidenceRefs(values: GuideFrontmatter['evidence_refs']) {
  return Array.isArray(values)
    ? values
        .map((record) => {
          const label = record.label?.trim() ?? record.kind?.trim() ?? '';
          const details = [record.path ?? record.target ?? '', record.note ?? ''].filter(
            (value) => value.trim().length > 0,
          );

          if (label.length === 0) {
            return details.join('；');
          }

          return details.length > 0 ? `${label}（${details.join('；')}）` : label;
        })
        .filter((value) => value.trim().length > 0)
    : [];
}
function makeValueRow(label: string, value: string): MetadataRow | null {
  return value.trim().length > 0 ? { label, value } : null;
}
function makeListRow(label: string, items: string[]): MetadataRow | null {
  return items.length > 0 ? { label, items } : null;
}
function compactRows(rows: Array<MetadataRow | null>) {
  return rows.filter((row): row is MetadataRow => Boolean(row));
}
const verificationLevelValue = frontmatter.verificationLevelCode
  ? formatLabelValue(frontmatter.verificationLevelCode, verificationLevelLabels)
  : '';
const guideAudienceValue = formatLabelValue(frontmatter.guide_audience, guideAudienceLabels);
const guideSurfaceValue = formatLabelValue(frontmatter.guide_surface, guideSurfaceLabels);
const verificationClassValue = formatLabelValue(
  frontmatter.verification_class,
  verificationClassLabels,
);
const testedOnItems = formatTestedOn(frontmatter.tested_on);
const evidenceRefsItems = formatEvidenceRefs(frontmatter.evidence_refs);
const knownLimitationsItems = formatTextList(frontmatter.known_limitations);
const shippingLaneValue = formatLabelValue(frontmatter.shipping_lane, shippingLaneLabels);
const updateTriggerItems = formatCodeItems(frontmatter.updateTriggers, updateTriggerLabels);
const retestTriggerItems = formatCodeItems(frontmatter.retest_trigger, updateTriggerLabels);
const projection = resolvePublicProjection(frontmatter);
const expectedTemplate = getExpectedTemplateForRoute(frontmatter);
const expectedSiteType = getExpectedSiteTypeForRoute(frontmatter);
const projectionSections = getRouteReaderSections(frontmatter);
const title = Astro.props.title ?? '指南資訊';
const intro =
  Astro.props.intro ??
  '先看上面幾格，就會知道這篇適唔適合你；下面再看證據、限制同何時要重新檢查。';
const fallbackRows =
  Astro.props.rows?.filter((row) => row.value.trim().length > 0).map((row) => ({ ...row })) ?? [];
const primaryRows =
  fallbackRows.length > 0
    ? fallbackRows
    : compactRows([
        makeValueRow('指南對象', guideAudienceValue || frontmatter.audience || ''),
        makeValueRow('公開路線', guideSurfaceValue),
        makeValueRow('驗證層級（對外承諾）', verificationLevelValue),
        makeValueRow('驗證分類（實際證據）', verificationClassValue),
        makeValueRow('公開通道', shippingLaneValue),
        makeValueRow('下次覆核', frontmatter.nextReviewAt ?? ''),
      ]);
const metadataSections: MetadataSection[] =
  fallbackRows.length > 0
    ? []
    : [
        {
          title: '基本資料',
          intro: '先用這區確認版本、平台與適合讀者。',
          rows: compactRows([
            makeValueRow('指南版本', frontmatter.guideVersion ?? ''),
            makeValueRow('已驗證於', frontmatter.verifiedAt ?? ''),
            makeValueRow(
              '平台',
              Array.isArray(frontmatter.platforms) ? frontmatter.platforms.join('、') : '',
            ),
            makeValueRow('適合讀者', frontmatter.audience ?? ''),
            makeValueRow('難度', frontmatter.difficulty ?? ''),
          ]),
        },
        {
          title: '證據與限制',
          intro: '這區用來說明目前有咩實測證據，仲有邊啲範圍未覆蓋。',
          rows: compactRows([
            makeListRow('實測環境', testedOnItems),
            makeListRow('證據參照', evidenceRefsItems),
            makeListRow('已知限制', knownLimitationsItems),
          ]),
        },
        {
          title: '重新檢查與維護',
          intro: '當官方流程、驗證結果或頁面時效有變，應優先看這區。',
          rows: compactRows([
            makeListRow('重新檢查時機', updateTriggerItems),
            makeListRow('再次實測條件', retestTriggerItems),
            makeValueRow('過期處理', frontmatter.stalePolicy ?? GUIDE_STALE_POLICY_TEXT),
          ]),
        },
      ].filter((section) => section.rows.length > 0);
const projectionRows = compactRows([
  makeValueRow(
    '公開類型',
    expectedSiteType ?? projection.siteTypeProjection ?? '',
  ),
  makeValueRow('中文模板', expectedTemplate ?? frontmatter.target_template ?? ''),
  makeListRow('讀者段落', projectionSections),
]);
const showProjectionSection = projectionRows.length > 0 && projection.isWave1SupportedRoute;
const tags = Array.isArray(Astro.props.tags)
  ? Astro.props.tags
  : Array.isArray(frontmatter.tags)
    ? frontmatter.tags.filter((tag) => tag.trim().length > 0)
    : [];
const hasMetadata =
  primaryRows.length > 0 || metadataSections.length > 0 || tags.length > 0 || showProjectionSection;
---

{hasMetadata && (
  <section class="loom-section loom-guide-metadata">
    <div class="loom-section-head">
      <div class="loom-eyebrow">指南資訊</div>
      <h2>{title}</h2>
      <p>{intro}</p>
    </div>

    {primaryRows.length > 0 && (
      <dl class="loom-guide-metadata-primary">
        {primaryRows.map((row) => (
          <div class="loom-guide-metadata-card">
            <dt>{row.label}</dt>
            <dd>{row.value}</dd>
          </div>
        ))}
      </dl>
    )}

    {metadataSections.length > 0 && (
      <div class="loom-guide-metadata-secondary">
        {metadataSections.map((section) => (
          <details class="loom-guide-metadata-disclosure">
            <summary>
              <strong>{section.title}</strong>
              <span>{section.intro}</span>
            </summary>
            <dl class="loom-guide-metadata-grid">
              {section.rows.map((row) => (
                <div class="loom-guide-metadata-row">
                  <dt>{row.label}</dt>
                  <dd>
                    {row.items ? (
                      <ul class="loom-guide-metadata-list">
                        {row.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    ) : (
                      row.value
                )}
              </dd>
            </div>
          ))}
        </dl>
          </details>
        ))}
      </div>
    )}

    {showProjectionSection && (
      <section class="loom-guide-metadata-panel">
        <div class="loom-guide-metadata-panel-head">
          <h3>公開投影</h3>
          <p>只顯示已凍結的公開類型與中文模板，唔會暴露內部 route truth。</p>
        </div>

        <dl class="loom-guide-metadata-grid">
          {projectionRows.map((row) => (
            <div class="loom-guide-metadata-row">
              <dt>{row.label}</dt>
              <dd>
                {row.items ? (
                  <ul class="loom-guide-metadata-list">
                    {row.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                ) : (
                  row.value
                )}
              </dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {tags.length > 0 && (
      <div class="loom-guide-metadata-tags">
        <strong>標籤</strong>
        <LabelList labels={tags} />
      </div>
    )}
  </section>
)}
