<button class="loom-theme-toggle" aria-label="Toggle theme" type="button">
  <span class="loom-theme-icon-light" aria-hidden="true">☀</span>
  <span class="loom-theme-icon-dark" aria-hidden="true">☾</span>
</button>

<style>
  .loom-theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 1px solid var(--loom-border);
    border-radius: 0.375rem;
    background: transparent;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    color: var(--loom-copy);
    transition: background 150ms ease;
  }

  .loom-theme-toggle:hover {
    background: var(--loom-accent-light);
  }

  :root[data-theme='dark'] .loom-theme-icon-light { display: none; }
  :root[data-theme='dark'] .loom-theme-icon-dark { display: inline; }
  :root:not([data-theme='dark']) .loom-theme-icon-light { display: inline; }
  :root:not([data-theme='dark']) .loom-theme-icon-dark { display: none; }
</style>

<script>
  document.querySelector('.loom-theme-toggle')?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('loom-theme', next);
  });
</script>
