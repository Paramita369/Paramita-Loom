++export function canBindLocalPort(host = '127.0.0.1') {
++  return new Promise((resolve) => {
++    const server = net.createServer();
++
++    server.once('error', (error) => {
++      resolve({ ok: false, error });
++    });
++
++    server.listen(0, host, () => {
++      server.close(() => {
++        resolve({ ok: true, error: null });
++      });
++    });
++  });
++}
