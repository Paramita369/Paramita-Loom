++
++
++def run_gemini(prompt: str, timeout: int = SDK_TIMEOUT) -> str:
++    """Try Gemini CLI first, fall back to SDK."""
++    if is_gemini_cli_available():
++        return run_gemini_cli(prompt)
++
++    try:
